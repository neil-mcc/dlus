# --- Site -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://dlusrecovery.com

# --- Sanity -----------------------------------------------------------------
# Create a project with `npx sanity init` (run from this directory) and paste
# the resulting projectId here. Dataset is usually "production".
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Server-only write token used by `npm run sanity:seed` and any future
# revalidation routes. Generate one in the Sanity dashboard → API → Tokens.
SANITY_API_TOKEN=

# --- Resend (contact form) --------------------------------------------------
# Get a key from https://resend.com. Verify the sending domain before launch.
# All three vars below are required for the /contact form to deliver mail —
# without CONTACT_FORM_TO_EMAIL, submissions fail silently with a 500.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Dlús Recovery <hello@dlusrecovery.com>"
CONTACT_FORM_TO_EMAIL=

# --- Analytics --------------------------------------------------------------
# Optional. Leave blank to disable GA4. Vercel Analytics is auto-enabled.
NEXT_PUBLIC_GA_ID=
